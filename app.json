{
  "expo": {
    "name": "RAYZATECH",
    "slug": "rayzatech-mobile",
    "version": "1.0.2",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "rayzatechmobile",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/icon.png"
    },
    "android": {
      "package": "com.rayzatech.mobile",
      "versionCode": 3,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.RECORD_AUDIO"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-splash-screen",
      "expo-sqlite",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "RAYZATECH necesita acceder a tus fotos para registrar evidencias.",
          "cameraPermission": "RAYZATECH necesita usar la cámara para registrar evidencias de gestión."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "RAYZATECH necesita acceder a tu ubicación para validar la gestión en campo.",
          "locationWhenInUsePermission": "RAYZATECH necesita acceder a tu ubicación para validar la gestión en campo."
        }
      ],
      "expo-camera",
      "@react-native-community/datetimepicker",
      "expo-image"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "fd448da8-8833-4845-81c7-362f8c15560a"
      }
    },
    "owner": "osalazar89"
  }
}
